{
  "name": "@honem/teletext-core",
  "version": "0.5.2",
  "description": "Provider-agnostic teletext fetcher, cache, and topic API. Powers @honem/teletext-mcp and @honem/teletext-cli.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": ["teletext", "broadcast", "ceska-televize", "svt", "library"],
  "author": "honem <development@honzanemecek.cz>",
  "license": "MIT",
  "engines": { "node": ">=18" }
}
